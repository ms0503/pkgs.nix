+void MozcEngine::ScheduleCallback(uint32_t delay_millisec,
+                                  std::function<void()> callback) {
+  callbackTimers_.erase(
+      std::remove_if(callbackTimers_.begin(), callbackTimers_.end(),
+                     [](const auto &timer) { return !timer->isEnabled(); }),
+      callbackTimers_.end());
+
+  const uint64_t delay_usec = static_cast<uint64_t>(delay_millisec) * 1000;
+  auto timer = instance_->eventLoop().addTimeEvent(
+      CLOCK_MONOTONIC, now(CLOCK_MONOTONIC) + delay_usec, 0,
+      [callback = std::move(callback)](EventSourceTime *, uint64_t) mutable {
+        callback();
+        return false;
+      });
+  timer->setOneShot();
+  callbackTimers_.push_back(std::move(timer));
+}
